# Copy to `.env.local` (gitignored). Server-only secrets must never use NEXT_PUBLIC_.
# Local dev runbook: docs/foundation/setup.md
# Amplify pilot deploy: copy dashboard/amplify.env.example → amplify.env.local (gitignored),
# fill from pilot vault, then npm run amplify:sync-env (docs/guides/operators/aws-pilot-runbook.md § 3)

# Control-layer proxy (required for /api/control/* route handlers)
# Fastify API default: http://localhost:3000 (repo root: npm run dev)
# Dashboard dev default: http://localhost:3001 (dashboard: npm run dev)
# Both must not share the same port — see docs/foundation/setup.md § Port conflict
CONTROL_LAYER_API_BASE_URL=http://localhost:3000
CONTROL_LAYER_API_KEY=

# Optional org pin (replaces legacy VITE_ORG_ID)
CONTROL_LAYER_ORG_ID=

# Optional admin key for ingestion preflight dry-run (server-only; /api/preflight)
CONTROL_LAYER_ADMIN_API_KEY=

# Client-visible label only (safe to expose)
NEXT_PUBLIC_APP_NAME=Decision Panel

# Overview cross-filter sync toggle (default true; set false to hide "Sync filters")
NEXT_PUBLIC_OVERVIEW_CROSS_FILTER=true

# Passphrase gate — see docs/specs/dashboard-passphrase-gate.md
DASHBOARD_ACCESS_CODE=
DASHBOARD_SESSION_TTL_HOURS=8
COOKIE_SECRET=
