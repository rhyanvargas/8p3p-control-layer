# Amplify Console → Environment variables (SSR runtime — not client bundle).
# Copy values from the pilot environment record (vault); never commit secrets.
# Runbook: docs/guides/operators/aws-pilot-runbook.md § 3.2
# Sync via: npm run amplify:sync-env (requires AMPLIFY_APP_ID)

# Control-layer proxy (required)
CONTROL_LAYER_API_BASE_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/pilot
CONTROL_LAYER_API_KEY=
CONTROL_LAYER_ORG_ID=southwest-charter

# Passphrase gate (required for pilot)
DASHBOARD_ACCESS_CODE=
COOKIE_SECRET=

# Optional
DASHBOARD_SESSION_TTL_HOURS=8
CONTROL_LAYER_ADMIN_API_KEY=
NEXT_PUBLIC_APP_NAME=Decision Panel
