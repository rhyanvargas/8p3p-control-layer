{
  "name": "8p3p-control-layer",
  "version": "1.0.0",
  "description": "**A vendor-agnostic, contract-driven intelligence engine for adaptive learning systems**",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "precheck": "node scripts/ensure-better-sqlite3.mjs",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:contracts": "vitest run tests/contracts",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "validate:schemas": "tsx scripts/validate-schemas.ts",
    "validate:contracts": "tsx scripts/validate-contracts.ts",
    "validate:api": "redocly lint docs/api/openapi.yaml",
    "generate:api-key": "node scripts/generate-api-key.mjs",
    "seed:springs-demo": "node scripts/seed-springs-demo.mjs",
    "build:dashboard": "cd dashboard && npm ci --quiet && npm run build",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "check": "npm run build && npm run validate:schemas && npm run validate:contracts && npm run validate:api && npm run lint && npm test",
    "cdk:synth": "cd infra && npm ci --quiet && npx cdk synth",
    "cdk:deploy": "cd infra && npm ci --quiet && npx cdk deploy --require-approval never",
    "cdk:diff": "cd infra && npx cdk diff"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhyanvargas/8p3p-control-layer.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "module",
  "bugs": {
    "url": "https://github.com/rhyanvargas/8p3p-control-layer/issues"
  },
  "homepage": "https://github.com/rhyanvargas/8p3p-control-layer#readme",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1019.0",
    "@aws-sdk/lib-dynamodb": "^3.1027.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "ajv": "^8.17.1",
    "aws-lambda-fastify": "^2.2.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.2"
  },
  "devDependencies": {
    "@redocly/cli": "^1.31.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.1.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  }
}
