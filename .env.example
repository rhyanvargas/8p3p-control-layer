# Copy to `.env` and optionally `.env.local` (gitignored).
# Runbook: docs/foundation/setup.md  |  This file is the source of truth for variable names/defaults.

PORT=3000
LOG_LEVEL=info

# API_KEY=
# API_KEY_ORG_ID=
# When API_KEY is set, use the same value as CONTROL_LAYER_API_KEY in dashboard/.env.local.

SIGNAL_BODY_LIMIT=1048576

IDEMPOTENCY_DB_PATH=./data/idempotency.db
SIGNAL_LOG_DB_PATH=./data/signal-log.db
STATE_STORE_DB_PATH=./data/state.db
INGESTION_LOG_DB_PATH=./data/ingestion-log.db
DECISION_DB_PATH=./data/decisions.db
# Educator feedback + view-log (docs/specs/educator-feedback-api.md). Server defaults
# to ./data/feedback.db when unset; declared here for parity with the other DB paths
# so all six SQLite files are visible in one place for the pilot-persistence recipe
# (docs/guides/pilot-host-deployment.md § 7).
FEEDBACK_DB_PATH=./data/feedback.db

DECISION_POLICY_PATH=./src/decision/policies/default.json

# TENANT_FIELD_MAPPINGS_PATH=
# FIELD_MAPPINGS_TABLE=
# When set, /v1/admin/mappings reads/writes tenant mappings in DynamoDB.
# When unset, /v1/admin/mappings uses an in-memory fallback store for local dev.
# FIELD_MAPPINGS_CACHE_TTL_MS=

# ADMIN_API_KEY=

# Dashboard passphrase gate (Decision Panel). See docs/specs/dashboard-passphrase-gate.md
DASHBOARD_ACCESS_CODE=
DASHBOARD_SESSION_TTL_HOURS=8
COOKIE_SECRET=

# Comma-separated browser origins allowed by @fastify/cors (standalone Next dashboard).
# Defaults to localhost:3000/3001 when unset. Example: https://dashboard.example.com
# DASHBOARD_ALLOWED_ORIGINS=

# AI educator explanations (docs/specs/ai-educator-explanations.md). Default off — pilot/SQLite
# hosts need no Bedrock or Gateway credentials when disabled.
# AI_EXPLANATIONS_ENABLED=false
# AI_PROVIDER=amazon-bedrock
# AI_MODEL=us.anthropic.claude-3-5-haiku-20241022-v1:0
# AI_REGION=us-east-1
# AI_MAX_OUTPUT_TOKENS=256
# AI_TEMPERATURE=0.2
# AI_TIMEOUT_MS=4000
# AI_MAX_RETRIES=2
# AI_GATEWAY_API_KEY=
# EDUCATOR_EXPLANATION_MAX_CHARS=480
# When AI_PROVIDER=gateway (local dev), set AI_GATEWAY_API_KEY and use e.g. AI_MODEL=anthropic/claude-haiku-4.5
