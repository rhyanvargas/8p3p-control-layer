PORT=3000
LOG_LEVEL=info

# API key for /v1/* (pilot). When set, requests must send x-api-key header.
# When unset, auth is disabled (local dev). Generate: npm run generate:api-key
# Server loads .env and .env.local at startup; use .env.local for local keys (gitignored).
# API_KEY=
# Optional. When set: server overrides request org_id with this value (one org per key; client cannot self-declare org).
# When unset: client's org_id in body/query is used. Use for single-tenant pilot; omit to let client choose org_id.
# API_KEY_ORG_ID=

# Max request size (bytes) for POST /v1/signals
SIGNAL_BODY_LIMIT=1048576

# SQLite database paths (created on first use)
IDEMPOTENCY_DB_PATH=./data/idempotency.db
SIGNAL_LOG_DB_PATH=./data/signal-log.db
STATE_STORE_DB_PATH=./data/state.db
DECISION_DB_PATH=./data/decisions.db

# Optional (defaults to src/decision/policies/default.json)
DECISION_POLICY_PATH=./src/decision/policies/default.json